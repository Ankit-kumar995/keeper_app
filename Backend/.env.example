# MongoDB Atlas Connection String
# Get from: https://cloud.mongodb.com → Connect → Connect your app
MONGO_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/keeper

# JWT Secret Key (generate any random string)
JWT_SECRET=your-super-secret-key-here

# Google OAuth Credentials
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=123456789-xxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Google Drive API Credentials
# Get from: Google Cloud Console → Enable Drive API → Create Service Account
GOOGLE_DRIVE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
your-private-key-content-here
-----END PRIVATE KEY-----
"

# Google Drive Folder ID (create a folder in Drive, share with service account, copy ID from URL)
GOOGLE_DRIVE_FOLDER_ID=1xxxxxxxxxxxxxxxxxxxxxxxx

# Server Port
PORT=5000