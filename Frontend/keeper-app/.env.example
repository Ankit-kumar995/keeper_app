# Backend API URL
# For local development: http://localhost:5000
# For production: your-render/railway-url
VITE_BACKEND_URL=http://localhost:5000

# Google OAuth Client ID
# Get from: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
VITE_GOOGLE_CLIENT_ID=123456789-xxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com